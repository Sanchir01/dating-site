# Скопируй этот файл в .env и подставь свои значения.
# ВАЖНО: без префикса VITE_ — эти переменные нужны только серверу
# и НЕ попадают в браузерную сборку.

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA...your-token...

# ID чата, куда слать заявки.
# Узнать: напиши боту, открой https://api.telegram.org/bot<ТОКЕН>/getUpdates
# и возьми chat.id (для личного чата — твой id, для группы — отрицательное число)
TELEGRAM_CHAT_ID=123456789
